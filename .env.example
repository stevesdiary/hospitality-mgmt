# ── Database ───────────────────────────────────────────────────────────────────
DB_NAME=hospitality_mgmt_db
DB_USER=your_db_username
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432
DB_DIALECT=postgres

# ── JWT ────────────────────────────────────────────────────────────────────────
# Minimum 32 chars (dev); minimum 64 chars (production)
JWT_SECRET=change_me_to_at_least_32_random_characters

# ── Backblaze B2 Storage ───────────────────────────────────────────────────────
B2_KEY_ID=your_backblaze_b2_key_id
B2_APPLICATION_KEY=your_backblaze_b2_application_key
B2_BUCKET_ID=your_backblaze_b2_bucket_id
B2_BUCKET_NAME=your_backblaze_b2_bucket_name

# ── Email (used for password-reset links) ─────────────────────────────────────
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASS=your_gmail_app_password

# ── Application ────────────────────────────────────────────────────────────────
LOCAL_PORT=3360
PUBLIC_URL=http://localhost:3360
NODE_ENV=development

# In production set this to your actual frontend origin, never "*"
CORS_ORIGIN=http://localhost:5173

# ── Upstash QStash (serverless queues) ────────────────────────────────────────
QSTASH_URL=https://qstash.upstash.io
QSTASH_TOKEN=your_qstash_token_here
QSTASH_CURRENT_SIGNING_KEY=your_current_signing_key_here
QSTASH_NEXT_SIGNING_KEY=your_next_signing_key_here
